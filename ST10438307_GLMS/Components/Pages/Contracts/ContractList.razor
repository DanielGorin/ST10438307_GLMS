@* Lists contracts with filter *@
@page "/contracts"
@inject IContractService ContractService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services

<div class="page-header">
    <h3>Contracts</h3>
    <button class="btn btn-primary" @onclick="GoToCreate">+ Add Contract</button>
</div>

<div class="filter-panel">
    <h6>Filter</h6>
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Start Date From</label>
            <input type="date" class="form-control" @bind="filterStartDate" />
        </div>
        <div class="col-md-3">
            <label class="form-label">End Date To</label>
            <input type="date" class="form-control" @bind="filterEndDate" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="filterStatus">
                <option value="">All</option>
                @foreach (var status in Enum.GetValues<ContractStatus>())
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button class="btn btn-primary" @onclick="ApplyFilter">Filter</button>
            <button class="btn btn-secondary" @onclick="ClearFilter">Clear</button>
        </div>
    </div>
</div>

<div class="glms-card" style="padding: 0; overflow: hidden;">
    @if (contracts == null)
    {
        <p style="padding: 1.5rem;">Loading...</p>
    }
    else if (contracts.Count == 0)
    {
        <div class="empty-state">No contracts found.</div>
    }
    else
    {
        <table class="glms-table">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Service Level</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Status</th>
                    <th>Agreement</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in contracts)
                {
                    <tr>
                        <td><strong>@contract.Client?.Name</strong></td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToShortDateString()</td>
                        <td>@contract.EndDate.ToShortDateString()</td>
                        <td>
                            <span class="badge @GetStatusBadge(contract.Status)">
                                @contract.Status
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                            {
                                <a href="/@contract.SignedAgreementPath"
                                   target="_blank"
                                   class="btn btn-sm btn-secondary">
                                    @System.IO.Path.GetFileName(contract.SignedAgreementPath)
                                </a>
                            }
                            else
                            {
                                <span style="color: var(--text-soft); font-size: 0.85rem;">none</span>
                            }
                        </td>
                        <td style="display: flex; gap: 0.5rem;">
                            <button class="btn btn-sm btn-warning"
                                    @onclick="() => GoToEdit(contract.Id)">
                                Edit
                            </button>
                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => DeleteContract(contract.Id)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Contract>? contracts;
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;
    private string filterStatus = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadContracts();
    }

    private async Task LoadContracts()
    {
        contracts = await ContractService.GetAllContractsAsync();
    }

    private async Task ApplyFilter()
    {
        ContractStatus? status = string.IsNullOrEmpty(filterStatus)
            ? null
            : Enum.Parse<ContractStatus>(filterStatus);

        contracts = await ContractService.GetFilteredContractsAsync(
            filterStartDate, filterEndDate, status);
    }

    private async Task ClearFilter()
    {
        filterStartDate = null;
        filterEndDate = null;
        filterStatus = "";
        await LoadContracts();
    }

    private void GoToCreate() => Nav.NavigateTo("/contracts/create");
    private void GoToEdit(int id) => Nav.NavigateTo($"/contracts/edit/{id}");

    private async Task DeleteContract(int id)
    {
        await ContractService.DeleteContractAsync(id);
        await LoadContracts();
    }

    private string GetStatusBadge(ContractStatus status) => status switch
    {
        ContractStatus.Active => "bg-success",
        ContractStatus.Expired => "bg-danger",
        ContractStatus.OnHold => "bg-warning",
        _ => "bg-secondary"
    };
}