@* contract create form - uses abstract factory based on selected type, handles pdf upload *@
@page "/contracts/create"
@inject IContractService ContractService
@inject IClientService ClientService
@inject IFileUploadService FileUploadService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services
@using ST10438307_GLMS.Decorators
@using Microsoft.AspNetCore.Components.Forms

<div class="page-header">
    <h3>Add Contract</h3>
</div>

@if (clients == null)
{
    <p>Loading...</p>
}
else
{
    <div class="glms-card" style="max-width: 560px;">
        <div class="mb-3">
            <label class="form-label">Client</label>
            <select class="form-select" @bind="selectedClientId">
                <option value="0">-- select a client --</option>
                @foreach (var client in clients)
                {
                    <option value="@client.Id">@client.Name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Contract Type</label>
            <select class="form-select" @bind="contractType">
                <option value="Standard">Standard</option>
                <option value="SLA">SLA</option>
                <option value="International">International</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Start Date</label>
            <input type="date" class="form-control" @bind="contract.StartDate" />
        </div>
        <div class="mb-3">
            <label class="form-label">End Date</label>
            <input type="date" class="form-control" @bind="contract.EndDate" />
        </div>

        @* pdf upload - decorator handles validation  *@
        <div class="mb-3">
            <label class="form-label">Signed Agreement (PDF only)</label>
            <InputFile OnChange="HandleFileSelected" accept=".pdf" class="form-control" />
            @if (!string.IsNullOrEmpty(selectedFileName))
            {
                <div style="margin-top: 0.4rem; color: var(--success); font-size: 0.9rem;">
                    @selectedFileName selected
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-3">@errorMessage</div>
        }

        <div style="display: flex; gap: 0.75rem;">
            <button class="btn btn-primary" @onclick="HandleSubmit">Save Contract</button>
            <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </div>
    </div>
}

@code {
    private List<Client>? clients;
    private Contract contract = new();
    private string contractType = "Standard";
    private int selectedClientId = 0;
    private string errorMessage = string.Empty;

    //file upload state
    private IBrowserFile? selectedFile;
    private string selectedFileName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        clients = await ClientService.GetAllClientsAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File.Name; // shows the aneme
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (selectedClientId == 0)
        {
            errorMessage = "please select a client.";
            return;
        }

        //File Upload - decorator validates extension
        //-------------------------------------------------------
        if (selectedFile != null)
        {
            try
            {
                var path = await FileUploadService.UploadAsync(selectedFile);
                contract.SignedAgreementPath = path;
            }
            catch (InvalidOperationException ex)
            {
                errorMessage = ex.Message; //wrong file type
                return;
            }
        }
        //-------------------------------------------------------

        contract.ClientId = selectedClientId;
        await ContractService.AddContractAsync(contract, contractType);
        Nav.NavigateTo("/contracts");
    }

    private void Cancel() => Nav.NavigateTo("/contracts");
}