@* lists all clients (edit and delete) *@
@page "/clients"
@inject IClientService ClientService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services

<div class="page-header">
    <h3>Clients</h3>
    <button class="btn btn-primary" @onclick="GoToCreate">+ Add Client</button>
</div>

<div class="glms-card" style="padding: 0; overflow: hidden;">
    @if (clients == null)
    {
        <p style="padding: 1.5rem;">Loading...</p>
    }
    else if (clients.Count == 0)
    {
        <div class="empty-state">No clients yet — add one to get started.</div>
    }
    else
    {
        <table class="glms-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Region</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in clients)
                {
                    <tr>
                        <td><strong>@client.Name</strong></td>
                        <td class="cell-truncate">@client.ContactDetails</td>
                        <td>@client.Region</td>
                        <td style="display: flex; gap: 0.5rem;">
                            <button class="btn btn-sm btn-warning"
                                    @onclick="() => GoToEdit(client.Id)">
                                Edit
                            </button>
                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => DeleteClient(client.Id)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Client>? clients;

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        clients = await ClientService.GetAllClientsAsync();
    }

    private void GoToCreate() => Nav.NavigateTo("/clients/create");
    private void GoToEdit(int id) => Nav.NavigateTo($"/clients/edit/{id}");

    private async Task DeleteClient(int id)
    {
        await ClientService.DeleteClientAsync(id);
        await LoadClients();
    }
}