@* form to create a new client *@
@page "/clients/create"
@inject IClientService ClientService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services

<div class="page-header">
    <h3>Add Client</h3>
</div>

<div class="glms-card" style="max-width: 520px;">
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" @bind="client.Name" placeholder="e.g. Acme Freight Ltd" />
    </div>
    <div class="mb-3">
        <label class="form-label">Contact Details</label>
        <input class="form-control" @bind="client.ContactDetails" placeholder="e.g. jane@acme.com" />
    </div>
    <div class="mb-3">
        <label class="form-label">Region</label>
        <input class="form-control" @bind="client.Region" placeholder="e.g. Southern Africa" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }

    <div style="display: flex; gap: 0.75rem;">
        <button class="btn btn-primary" @onclick="HandleSubmit">Save Client</button>
        <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
    </div>
</div>

@code {
    private Client client = new();
    private string errorMessage = string.Empty;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(client.Name) ||
            string.IsNullOrWhiteSpace(client.ContactDetails) ||
            string.IsNullOrWhiteSpace(client.Region))
        {
            errorMessage = "all fields are required.";
            return;
        }

        await ClientService.AddClientAsync(client);
        Nav.NavigateTo("/clients");
    }

    private void Cancel() => Nav.NavigateTo("/clients");
}