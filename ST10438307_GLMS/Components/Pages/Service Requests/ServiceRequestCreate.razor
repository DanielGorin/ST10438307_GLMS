@* form to create a service request - observer blocks expired or onhold contracts *@
@page "/servicerequests/create"
@inject IServiceRequestService ServiceRequestService
@inject IContractService ContractService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services

<div class="page-header">
    <h3>Add Service Request</h3>
</div>

@if (contracts == null)
{
    <p>Loading...</p>
}
else
{
    <div class="glms-card" style="max-width: 560px;">
        <div class="mb-3">
            <label class="form-label">Contract</label>
            <select class="form-select" @bind="selectedContractId">
                <option value="0">-- select a contract --</option>
                @foreach (var contract in contracts)
                {
                    <option value="@contract.Id">
                        @contract.Client?.Name — @contract.ServiceLevel (@contract.Status)
                    </option>
                }
            </select>
        </div>

        @* show warning if selected contract cant accept requests *@
        @if (selectedContractId > 0)
        {
            var selected = contracts.FirstOrDefault(c => c.Id == selectedContractId);
            if (selected != null &&
            (selected.Status == ContractStatus.Expired ||
            selected.Status == ContractStatus.OnHold))
            {
                <div class="alert alert-danger mb-3">
                    ⚠️ this contract is <strong>@selected.Status</strong> — service requests are blocked
                </div>
            }
        }

        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3"
                      @bind="serviceRequest.Description"
                      placeholder="describe the service required..."></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Cost (USD)</label>
            <input type="number" step="0.01" class="form-control"
                   @bind="serviceRequest.CostUSD" />
            <div class="form-text" style="color: var(--text-soft); font-size: 0.82rem; margin-top: 0.3rem;">
                ZAR conversion added in phase 7
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-3">@errorMessage</div>
        }

        <div style="display: flex; gap: 0.75rem;">
            <button class="btn btn-primary" @onclick="HandleSubmit">Save Request</button>
            <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </div>
    </div>
}

@code {
    private List<Contract>? contracts;
    private ServiceRequest serviceRequest = new();
    private int selectedContractId = 0;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        contracts = await ContractService.GetAllContractsAsync();
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (selectedContractId == 0)
        {
            errorMessage = "please select a contract.";
            return;
        }

        if (string.IsNullOrWhiteSpace(serviceRequest.Description))
        {
            errorMessage = "description is required.";
            return;
        }

        serviceRequest.ContractId = selectedContractId;
        serviceRequest.CostZAR = 0; 

        try
        {
            await ServiceRequestService.AddServiceRequestAsync(serviceRequest);
            Nav.NavigateTo("/servicerequests");
        }
        catch (InvalidOperationException ex)
        {
            // observer contract is expired or on hold
            errorMessage = ex.Message;
        }
    }

    private void Cancel() => Nav.NavigateTo("/servicerequests");
}