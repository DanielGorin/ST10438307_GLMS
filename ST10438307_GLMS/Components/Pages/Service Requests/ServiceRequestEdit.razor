@* service request edit *@
@page "/servicerequests/edit/{id:int}"
@inject IServiceRequestService ServiceRequestService
@inject ICurrencyService CurrencyService
@inject NavigationManager Nav
@using ST10438307_GLMS.Models
@using ST10438307_GLMS.Services

<div class="page-header">
    <h3>Edit Service Request</h3>
</div>

@if (serviceRequest == null)
{
    <p>Loading...</p>
}
else
{
    <div class="glms-card" style="max-width: 600px;">
        <div class="mb-3">
            <label class="form-label">Contract</label>
            <input class="form-control"
                   value="@(serviceRequest.Contract?.Client?.Name) — @(serviceRequest.Contract?.ServiceLevel)"
                   disabled />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3"
                      @bind="serviceRequest.Description"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">
                Cost
                @if (exchangeRate > 0)
                {
                    <span style="color: var(--text-soft); font-size: 0.82rem; font-weight: 400; margin-left: 0.5rem;">
                        rate: 1 USD = @exchangeRate.ToString("F4") ZAR
                    </span>
                }
            </label>

            <div style="display: flex; gap: 0.75rem; align-items: flex-end;">
                <div style="flex: 1;">
                    <div style="color: var(--text-soft); font-size: 0.82rem; margin-bottom: 0.25rem;">USD</div>
                    <input type="number"
                           step="0.01"
                           class="form-control"
                           @bind:get="usdDisplay"
                           @bind:set="HandleUsdSet"
                           @bind:event="oninput"
                           placeholder="0.00" />
                </div>
                <div style="padding-bottom: 0.6rem; color: var(--text-soft); font-size: 1.2rem;">
                    =
                </div>
                <div style="flex: 1;">
                    <div style="color: var(--text-soft); font-size: 0.82rem; margin-bottom: 0.25rem;">ZAR</div>
                    <input type="number"
                           step="0.01"
                           class="form-control"
                           @bind:get="zarDisplay"
                           @bind:set="HandleZarSet"
                           @bind:event="oninput"
                           placeholder="0.00" />
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="serviceRequest.Status">
                @foreach (var status in Enum.GetValues<ServiceRequestStatus>())
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-3">@errorMessage</div>
        }

        <div style="display: flex; gap: 0.75rem;">
            <button class="btn btn-primary" @onclick="HandleSubmit">Save Changes</button>
            <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ServiceRequest? serviceRequest;
    private string errorMessage = string.Empty;
    private bool initialised = false;

    //currency state
    private decimal exchangeRate = 0;
    private decimal usdDisplay = 0;
    private decimal zarDisplay = 0;

    protected override async Task OnInitializedAsync()
    {
        serviceRequest = await ServiceRequestService.GetServiceRequestByIdAsync(Id);
        exchangeRate = await CurrencyService.GetUsdToZarRateAsync();
    }
    // waits for both the database and exchange rate to be ready before pre-filling the currency boxes
    //This Section was created with teh assistance of AI
    //-----------------------------------------------------------------------------------------------
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!initialised && serviceRequest != null && exchangeRate > 0)
        {
            zarDisplay = Math.Round(serviceRequest.CostZAR, 2);
            usdDisplay = Math.Round(CurrencyService.ConvertZarToUsd(zarDisplay, exchangeRate), 2);
            initialised = true;
            StateHasChanged();
        }
    }
    //-----------------------------------------------------------------------------------------------


    //Input Handlers
    //-----------------------------------------------------------------------------------------------
    private void HandleUsdSet(decimal value)
    {
        usdDisplay = Math.Round(value, 2);
        zarDisplay = Math.Round(CurrencyService.ConvertUsdToZar(usdDisplay, exchangeRate), 2);
    }

    private void HandleZarSet(decimal value)
    {
        zarDisplay = Math.Round(value, 2);
        usdDisplay = Math.Round(CurrencyService.ConvertZarToUsd(zarDisplay, exchangeRate), 2);
    }
    //-----------------------------------------------------------------------------------------------

    private async Task HandleSubmit()
    {
        if (serviceRequest == null) return;
        errorMessage = string.Empty;

        if (zarDisplay <= 0)
        {
            errorMessage = "please enter a cost amount.";
            return;
        }

        serviceRequest.CostZAR = zarDisplay;

        await ServiceRequestService.UpdateServiceRequestAsync(serviceRequest);
        Nav.NavigateTo("/servicerequests");
    }

    private void Cancel() => Nav.NavigateTo("/servicerequests");
}